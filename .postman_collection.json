          "raw": "{\n    \"vs_currency\": \"usd\",\n    \"history_days\": 30\n,  \"fetch_historical\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/token/:id/insight",
          "host": ["{{base_url}}"],
